{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "icon": ["icons/icon.ico"],
    "resources": [],
    "externalBin": [],
    "copyright": "© 2025 LOUST",
    "category": "Utility",
    "shortDescription": "Network Optimization Tool",
    "longDescription": "NetBoozt brings network optimization and DNS tooling to desktop systems"
  },
  "productName": "NetBoozt",
  "mainBinaryName": "NetBoozt",
  "version": "3.0.2",
  "identifier": "pro.loust.netboozt",
  "plugins": {},
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "NetBoozt",
        "width": 1000,
        "height": 700,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "transparent": false,
        "useHttpsScheme": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}